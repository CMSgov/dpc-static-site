{
  "$schema": "https://raw.githubusercontent.com/streetsidesoftware/cspell/main/cspell.schema.json",
  "version": "0.2",
  "language": "en-US",
  "files": [
    "./src/**/*.{html,md,mdx}"
  ],
  "ignorePaths": [
    ".cspell.json",
    "dist/",
    "*.min.*",
    "**/*rtl*",
    "**/tests/**"
  ],
  "useGitignore": true,
  "ignoreRegExpList": [
    // Ignores long random tokens
    "/[A-Za-z0-9]{24,}/"
  ],
  "words": [
    "PKCE",
    "codeverifier",
    "FHIR",
    "claimtype",
    "CARIN",
    "searchset",
    "resultset",
    "valueset",
    "databanks",
    "conveniens",
    "CNTL",
    "HICN",
    "hicn",
    "HCPCS",
    "MDFR",
    "codeset",
    "CSPINV",
    "codeable",
    "DMEPOS",
    "codesystem",
    "ENCNTR",
    "PWXXXXX",
    "billableperiod",
    "flinstone",
    "fflinstone",
    "CPCDS",
    "SUBSIDIZ",
    "pseudonymized",
    "PRVDR",
    "CDPDE",
    "BCDA",
    "FISS",
    "endcapture",
    "endraw",
    "tealium",
    "Tealium",
    "utag",
    "Touchpoints",
    "USWDS",
    "RSASSA",
    "bluebutton",
    "maxw",
    "borderless",
    "copybutton",
    "dgst",
    "outform",
    "pubout",
    "Datetimes",
    "Datatypes",
    "AGNT",
    "Wyman",
    // fake names that are being flagged as misspelled
    "Holguín",
    // uri encoded characters ending in "A" that are being flagged as misspelled
    "Aietf",
    "Aparams",
    "Aoauth",
    "Aclient",
    "Ajwt"
  ]
}