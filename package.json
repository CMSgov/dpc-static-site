{
  "scripts": {
    "dev": "concurrently \"npm run assets:serve\" \"npm run jekyll:serve\"",
    "build": "npm run assets:build && npm run jekyll:build",
    "assets:serve": "gulp updateUswds && gulp watch",
    "assets:build": "gulp updateUswds && gulp compile",
    "jekyll:serve": "bundle exec jekyll serve --source ./src",
    "jekyll:build": "bundle exec jekyll build --source ./src",
    "pa11y": "pa11y-ci --config pa11yci.local.json --sitemap https://d16450h30z080t.cloudfront.net/feature/uswds-redesign/sitemap.xml --sitemap-exclude /*.pdf --sitemap-find https://dpc.cms.gov/ --sitemap-replace https://d16450h30z080t.cloudfront.net/",
    "unlighthouse": "npx unlighthouse --site http://localhost:4000",
    "gulp": "gulp",
    "update:npm": "npx taze",
    "update:gems": "bundle update"
  },
  "dependencies": {
    "@uswds/compile": "^1.3.1",
    "@uswds/uswds": "^3.13.0",
    "concurrently": "^9.2.1",
    "gulp": "^5.0.1"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "pa11y-ci": "^4.1.0",
    "taze": "19.8.1"
  }
}